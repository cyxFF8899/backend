APP_NAME=Agri Backend
DB_PATH=backend/data/chat.db

# LLM (OpenAI-compatible)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=glm-4.7
DASHSCOPE_TEMPERATURE=0.2
DASHSCOPE_MAX_TOKENS=1200

# RAG
EMBEDDING_MODEL_NAME=BAAI/bge-small-zh-v1.5
EMBEDDING_HF_ENDPOINT=https://hf-mirror.com
CHROMA_PERSIST_DIR=backend/data/chroma
CHROMA_COLLECTION_NAME=agri_knowledge
INDEX_DATA_DIR=backend/data/raw
INDEX_AUTO_BUILD=true
RAG_CHUNK_SIZE=380
RAG_CHUNK_OVERLAP=60
CHROMA_ADD_BATCH_SIZE=128
TOP_K_HITS=3
HIT_MAX_CHARS=700

# Neo4j
NEO4J_URI=bolt://8.134.53.224:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Context memory
CONTEXT_WINDOW_TURNS=5
FOLLOWUP_MAX_QUESTIONS=3

# Intent
INTENT_MODEL_DIR=backend/models/intent/best_model
INTENT_MAPPING_PATH=backend/models/intent/best_model/intent_to_id.json
INTENT_CONFIDENCE_THRESHOLD=0.7
NON_AGRI_KEYWORDS_CSV=python,java,代码,编程,股票,基金,币圈,比特币,娱乐新闻,明星八卦,足球比分,篮球比分,电影票房,旅游攻略,恋爱建议
AGRI_KEYWORDS_CSV=农业,作物,种植,播种,施肥,灌溉,病虫害,农药,农资,水稻,小麦,玉米,果树,蔬菜,大棚,苗情,墒情,农产品,收购,产量,农机

# Streaming
STREAM_CHUNK_SLEEP_MS=0
