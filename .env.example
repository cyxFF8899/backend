APP_NAME=Agri Backend
DB_PATH=backend/data/chat.db

# LLM (DashScope OpenAI-compatible)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.5-plus
DASHSCOPE_TEMPERATURE=0.2
DASHSCOPE_MAX_TOKENS=1200

# Intent + retrieval + KG
INTENT_RESOURCES_DIR=IntentRecognition/semantic/resources
KG_GRAPH_PATH=KnowledgeRetrieval/knowledge_base/knowledge_graph.json
KG_SAMPLES_PATH=KnowledgeGraph/data/samples/samples.json
TOP_K_HITS=4
HIT_MAX_CHARS=700
HISTORY_LIMIT=6

# Streaming
STREAM_CHUNK_SLEEP_MS=0
